# ============================================
# Lenco by Broadpay Payment Gateway
# ============================================

# Environment: 'sandbox' for testing, 'production' for live
NEXT_PUBLIC_LENCO_ENVIRONMENT=sandbox

# Public key (safe for frontend - used in payment widget)
# Get from: https://app.lenco.co → LencoPay/Collections → API Keys
NEXT_PUBLIC_LENCO_PUBLIC_KEY=your_public_key_here

# Secret key (SERVER-SIDE ONLY - never expose to frontend)
# Used for: payment verification API calls, webhook signature verification
LENCO_SECRET_KEY=your_secret_key_here

# ============================================
# Supabase (must include service role key for payment processing)
# ============================================
# SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
# (This should already exist in your env - needed for webhook/verify endpoints)
