rules_version = '2';

// See: https://firebase.google.com/docs/firestore/security/get-started
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if a user is an admin by their specific UID.
    function isAdmin() {
      return request.auth.uid == 'RauWH3Dzl0fO17pxBFD4mud7i9u2';
    }

    // Helper function to check if a user is the owner of a document.
    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    // Helper function to check if the user is authenticated.
    function isAuthenticated() {
      return request.auth != null;
    }

    // /users/{userId}
    // Users can read/write their own profile.
    // Admins can read/list all user profiles.
    match /users/{userId} {
      allow read, write: if isOwner(userId);
      allow list: if isAdmin();
    }

    // /notes/{noteId}
    // Any authenticated user can read published notes.
    // Teachers/Admins can create, update, delete their own notes.
    // Admins can list all notes.
    match /notes/{noteId} {
      allow read: if isAuthenticated() && resource.data.visibility == 'published';
      allow create: if isAuthenticated();
      allow update, delete: if isOwner(resource.data.createdBy) || isAdmin();
      allow list: if isAdmin();
    }
    
    // /quizzes/{quizId}
    // Any authenticated user can read published quizzes.
    // Teachers/Admins can create, update, delete their own quizzes.
    // Admins can list all quizzes.
    match /quizzes/{quizId} {
       allow read: if isAuthenticated() && resource.data.visibility == 'published';
       allow create: if isAuthenticated();
       allow update, delete: if isOwner(resource.data.createdBy) || isAdmin();
       allow list: if isAdmin();
    }

    // /questions/{questionId}
    // Authenticated users can read questions (as they are part of quizzes).
    // Teachers/Admins can manage questions.
    match /questions/{questionId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAuthenticated();
    }

    // /subjects/{subjectId}
    // All authenticated users can read the list of subjects.
    match /subjects/{subjectId} {
      allow read: if isAuthenticated();
    }
    
    // /classes/{classId}
    // Teachers own their classes. Students are members.
    // This path is not used directly in the app, but we can secure it.
    match /classes/{classId} {
      allow read: if isOwner(resource.data.teacherId) || request.auth.uid in resource.data.studentIds;
      allow create: if isOwner(request.resource.data.teacherId);
      allow update: if isOwner(resource.data.teacherId); // Allows teacher to add/remove students
      allow delete: if isOwner(resource.data.teacherId);
    }
    
    // Subcollections
    match /{path=**}/quizAttempts/{attemptId} {
      allow create: if isOwner(request.resource.data.userId);
      allow read: if isOwner(resource.data.userId) || isAdmin();
    }
    
    match /users/{userId}/classes/{classId} {
        allow read, write, delete: if isOwner(userId);
    }

    match /users/{userId}/classes/{classId}/announcements/{announcementId} {
        allow read, write, delete: if isOwner(userId);
    }
    
    match /assignments/{assignmentId} {
        allow read, create, delete: if isAuthenticated();
    }

    // Default deny all other access
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
