# Supabase Configuration
# Get these from your Supabase project settings: https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key-here

# Supabase Service Role Key (KEEP SECRET - Server-side only)
# Used for admin operations that bypass RLS
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# OpenAI API Configuration
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here

# Application Configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=IGCSE Simplified
NODE_ENV=development

# Admin Configuration
# Email address for the initial super admin user
ADMIN_EMAIL=admin@example.com

# Optional: Error Tracking
# Sign up at https://sentry.io for error monitoring
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=

# Optional: Analytics
# Add your analytics tracking IDs here
NEXT_PUBLIC_GA_ID=
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=

# Optional: Email Service (for notifications)
# Configure if you want to send emails
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=

# Optional: File Upload Limits
MAX_FILE_SIZE_MB=50
ALLOWED_FILE_TYPES=pdf,jpg,jpeg,png

# Optional: Rate Limiting
RATE_LIMIT_REQUESTS_PER_MINUTE=60

# Security
# Generate a random secret for session encryption
SESSION_SECRET=your-random-secret-here-min-32-chars
